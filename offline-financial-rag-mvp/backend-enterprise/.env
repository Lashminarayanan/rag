
# =========================
# Shared configuration
# =========================

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=financial_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

REPORTS_DIR=./sample_data/reports
EMBEDDING_DIM=768

# =========================
# Parsing options
# =========================
# Recommended for MVP:
# USE_DOCLING=false
# This avoids OCR-heavy Docling preprocessing and uses PyPDF by default.
USE_DOCLING=false

# If USE_DOCLING=true and DOCLING_PREFER=true,
# Docling will be attempted first.
DOCLING_PREFER=false

# =========================
# Backend / UI
# =========================

PYTHON_QUERY_WORKER=C:/Program Files/Python313/python.exe
RAG_PYTHON_ENTRY=../rag/app/query_worker.py

BACKEND_PORT=8080
STREAMLIT_BACKEND_URL=http://localhost:8080
